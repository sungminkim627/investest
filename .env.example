NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Tiingo API key for search + adjusted EOD data
MARKET_DATA_API_KEY=YOUR_TIINGO_API_KEY
MARKET_DATA_BASE_URL=https://api.tiingo.com
# Metadata full-sync job control (optional)
INSTRUMENT_SYNC_PAGE_SIZE=5000
# CSV universe import directory (optional)
UNIVERSE_CSV_DIR=./data/universe
CSV_TOP_US_STOCKS=1000
CSV_TOP_CA_STOCKS=250
CSV_TOP_US_ETFS=500
CSV_TOP_CA_ETFS=250
# Weekly price sync controls (yfinance)
WEEKLY_PRICE_BATCH_SIZE=100
WEEKLY_PRICE_PAUSE_SECONDS=0.5
WEEKLY_PRICE_SYNC_MODE=incremental
WEEKLY_PRICE_INCREMENTAL_PERIOD=3mo
WEEKLY_PRICE_BACKFILL_PERIOD=10y

# Used for OAuth callback URL and local sign-in redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000
